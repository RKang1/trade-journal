# Shared PostgreSQL connection used by the API container.
TRADE_JOURNAL_DB_CONNECTION=Host=postgres;Port=5432;Database=trade_journal;Username=trade_journal;Password=yourpassword

# Google Identity client ID used by both the frontend and backend token checks.
TRADE_JOURNAL_GOOGLE_CLIENT_ID=

# Random secret used to sign JWTs. Generate one with:
#   openssl rand -base64 48
TRADE_JOURNAL_JWT_SIGNING_KEY=

# Frontend origin allowed by the backend CORS policy.
TRADE_JOURNAL_CORS_ORIGIN=https://journal.kangrc.com

# Frontend runtime API base URL injected into the nginx-served config.js.
TRADE_JOURNAL_FRONTEND_API_BASE_URL=https://journal.kangrc.com

# Bobby-style host publishing defaults. Keep the app on loopback and let nginx
# own the public hostname.
TRADE_JOURNAL_API_BIND=127.0.0.1
TRADE_JOURNAL_API_PUBLISHED_PORT=15211
TRADE_JOURNAL_FRONTEND_BIND=127.0.0.1
TRADE_JOURNAL_FRONTEND_PUBLISHED_PORT=14200
